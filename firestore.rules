rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //
    // DEVELOPMENT ONLY – tighten before exposing real attendees.
    // Deploy with: firebase deploy --only firestore:rules
    //

    match /members/{memberId} {
      allow read, write: if true;
    }

    match /qrCodes/{qrId} {
      allow read, write: if true;
    }

    // Public profile: connect form + connection stats (QR scan visitors)
    match /connections/{docId} {
      allow read, write: if true;
    }

    match /memberConnectionStats/{memberId} {
      allow read, write: if true;
    }

    // Competition winner entries
    match /winners/{docId} {
      allow read, write: if true;
    }
  }
}
